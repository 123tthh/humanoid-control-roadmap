# This course package contains Python source directories named ``env``.  The
# repository-level virtual-environment rule must not discard that source.
!rsl_rl_amp/env/
!rsl_rl_amp/env/**
!rsl_rl-main/rsl_rl/env/
!rsl_rl-main/rsl_rl/env/**
rsl_rl_amp/env/**/__pycache__/
rsl_rl_amp/env/**/*.pyc
rsl_rl-main/rsl_rl/env/**/__pycache__/
rsl_rl-main/rsl_rl/env/**/*.pyc
